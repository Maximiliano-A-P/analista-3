1) cuantos alumnos tiene cada materia

SELECT materias.nombre, COUNT(alumnos.id_alumnos)
FROM materias
JOIN alumnos ON materias.id_carrera = alumnos.id_carrera
GROUP BY materias.nombre;

2) cuantos alumnos tiene cada carrera (mostrar la cantidad de alumnos de todas las carreras)

SELECT carreras.nombre, carreras.id_carrera, COUNT(*)
FROM carreras
INNER JOIN alumnos ON alumnos.id_carrera = carreras.id_carrera
GROUP BY 2, 1;

